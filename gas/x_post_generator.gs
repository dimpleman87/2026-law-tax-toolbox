// ============================================================
// メイン関数（毎朝7時に自動実行）
// ============================================================
function generateDailyPost() {
  const ss = SpreadsheetApp.openById(SHEET_ID);
  const sheet = ss.getSheetByName("投稿管理") || ss.insertSheet("投稿管理");

  // ヘッダー作成（初回のみ）
  if (sheet.getLastRow() === 0) {
    sheet.getRange(1, 1, 1, 6).setValues([[
      "日付", "ツール名", "投稿文（コピペしてXへ）", "URL", "ハッシュタグ", "投稿済み"
    ]]);
    sheet.getRange(1, 1, 1, 6).setFontWeight("bold");
    sheet.setColumnWidth(3, 400);
    sheet.setColumnWidth(4, 300);
  }

  // 今日の日付
  const today = new Date();
  const dateStr = Utilities.formatDate(today, "Asia/Tokyo", "yyyy/MM/dd");

  // すでに今日の行があれば重複生成しない
  const lastRow = sheet.getLastRow();
  if (lastRow > 1) {
    const lastDate = sheet.getRange(lastRow, 1).getValue();
    if (lastDate === dateStr) {
      Logger.log("今日の投稿文は既に生成済みです: " + dateStr);
      return;
    }
  }

  // ローテーション：何番目のツールか（日数ベース）
  const startDate = new Date("2026-01-01");
  const dayCount = Math.floor((today - startDate) / (1000 * 60 * 60 * 24));
  const toolIndex = dayCount % TOOLS.length;
  const tool = TOOLS[toolIndex];

  // 投稿パターンも日次でローテーション
  const postIndex = dayCount % tool.posts.length;
  const postBody = tool.posts[postIndex];
  const toolUrl = SITE_URL + "/tools/" + tool.slug;
  const fullPost = postBody + "\n\n" + toolUrl + "\n\n" + tool.tags;

  // スプレッドシートに書き込み
  sheet.appendRow([
    dateStr,
    tool.title,
    fullPost,
    toolUrl,
    tool.tags,
    "未投稿"
  ]);

  // 投稿文をハイライト（未投稿は黄色背景）
  const newRow = sheet.getLastRow();
  sheet.getRange(newRow, 6).setBackground("#FFD700");

  Logger.log("投稿文を生成しました: " + tool.title + " (" + dateStr + ")");
}

// ============================================================
// 手動で7日分まとめて生成する関数（初期セットアップ用）
// ============================================================
function generateWeeklyPosts() {
  const ss = SpreadsheetApp.openById(SHEET_ID);
  const sheet = ss.getSheetByName("投稿管理") || ss.insertSheet("投稿管理");

  if (sheet.getLastRow() === 0) {
    sheet.getRange(1, 1, 1, 6).setValues([[
      "日付", "ツール名", "投稿文（コピペしてXへ）", "URL", "ハッシュタグ", "投稿済み"
    ]]);
    sheet.getRange(1, 1, 1, 6).setFontWeight("bold");
    sheet.setColumnWidth(3, 400);
    sheet.setColumnWidth(4, 300);
  }

  const startDate = new Date("2026-01-01");
  const today = new Date();

  for (let i = 0; i < 7; i++) {
    const targetDate = new Date(today);
    targetDate.setDate(today.getDate() + i);
    const dateStr = Utilities.formatDate(targetDate, "Asia/Tokyo", "yyyy/MM/dd");

    const dayCount = Math.floor((targetDate - startDate) / (1000 * 60 * 60 * 24));
    const toolIndex = dayCount % TOOLS.length;
    const tool = TOOLS[toolIndex];
    const postIndex = dayCount % tool.posts.length;
    const postBody = tool.posts[postIndex];
    const toolUrl = SITE_URL + "/tools/" + tool.slug;
    const fullPost = postBody + "\n\n" + toolUrl + "\n\n" + tool.tags;

    sheet.appendRow([
      dateStr,
      tool.title,
      fullPost,
      toolUrl,
      tool.tags,
      "未投稿"
    ]);

    const newRow = sheet.getLastRow();
    sheet.getRange(newRow, 6).setBackground("#FFD700");
  }

  Logger.log("7日分の投稿文を生成しました。");
}
